---
interface Patent {
  title: string;
  patentNumber: string;
  status: string;
  summary: string;
  domain: string;
  url: string;
  filingDate: string;
}

const { patent } = Astro.props as { patent: Patent };
---
<a
  href={patent.url}
  class="card block p-5 transition hover:border-slate-400 hover:shadow-sm focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-500"
  target="_blank"
  rel="noreferrer"
  aria-label={`Open patent: ${patent.title}`}
>
  <p class="text-xs uppercase tracking-wide text-slate-500">{patent.status} · {patent.patentNumber}</p>
  <h3 class="mt-1 text-lg font-semibold text-slate-900">{patent.title}</h3>
  <p class="mt-2 text-sm text-slate-700">{patent.summary}</p>
  <p class="mt-2 text-sm text-slate-600">Domain: {patent.domain}</p>
  <p class="mt-1 text-sm text-slate-600">Date: {patent.filingDate}</p>
  <span class="mt-3 inline-block text-sm underline">Patent link</span>
</a>
