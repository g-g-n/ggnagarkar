---
import profile from '../data/profile.json';
import SocialLinks from './SocialLinks.astro';
---
<section class="card fade-in p-5">
  <img
    src={profile.profileImage}
    alt="GG Nagarkar profile photo"
    class="mb-4 h-20 w-20 rounded-full border border-slate-200 object-cover"
    loading="lazy"
  />
  <h1 class="text-2xl font-semibold text-slate-900">{profile.name}</h1>
  <p class="mt-1 text-sm text-slate-700">{profile.headline}</p>
  <p class="mt-3 text-sm text-slate-600">{profile.location}</p>
  <p class="mt-1 text-sm text-slate-600">Education: {profile.education.join(', ')}</p>
  <p class="mt-4 text-sm text-slate-700">{profile.shortBio}</p>
  <div class="mt-5 flex flex-wrap gap-2">
    <a href={`mailto:${profile.email}`} class="rounded-full bg-slate-900 px-4 py-2 text-sm text-white">Email</a>
    <a href="/contact" class="rounded-full border border-slate-300 px-4 py-2 text-sm text-slate-700">Contact</a>
  </div>
  <div class="mt-5">
    <SocialLinks />
  </div>
</section>
