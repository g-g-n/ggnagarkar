---
interface Project {
  name: string;
  summary: string;
  status: string;
  tags: string[];
  url?: string;
  role?: string;
  period?: string;
  sourceUrls?: string[];
}

const { project } = Astro.props as { project: Project };
---
<article class="card group relative block p-5 transition hover:border-slate-400 hover:shadow-sm">
  {project.url && (
    <a
      href={project.url}
      class="absolute inset-0 rounded-lg focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-slate-500"
      target="_blank"
      rel="noreferrer"
      aria-label={`Open project: ${project.name}`}
    ></a>
  )}

  <div class="relative z-10">
  <h3 class="text-lg font-semibold text-slate-900">{project.name}</h3>
  {(project.role || project.period) && (
    <p class="mt-1 text-sm text-slate-600">
      {project.role}{project.role && project.period ? ' · ' : ''}{project.period}
    </p>
  )}
  <p class="mt-3 text-sm text-slate-700">{project.summary}</p>
  {(project.sourceUrls ?? []).length > 0 && (
    <p class="mt-3 text-xs text-slate-600">
      Sources:{' '}
      {(project.sourceUrls ?? []).slice(0, 2).map((sourceUrl, index) => (
        <>
          <a href={sourceUrl} class="relative z-20 underline" target="_blank" rel="noreferrer">ref {index + 1}</a>
          {index < Math.min((project.sourceUrls ?? []).length, 2) - 1 ? ', ' : ''}
        </>
      ))}
    </p>
  )}
  {project.url && <span class="mt-4 inline-block text-sm underline group-hover:text-slate-900">Visit</span>}
  </div>
</article>
