---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import projects from '../data/projects.json';

const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.ggnagarkar.com';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'CollectionPage',
  name: 'Projects and Products by GG Nagarkar',
  description: 'Applied AI Consulting, OpsRabbit, 7Targets, REAN Cloud, OpexSoftware, patents, and selected product work.',
  url: `${site}/projects`,
  hasPart: projects.map((project) => ({
    '@type': 'CreativeWork',
    name: project.name,
    description: project.summary,
    url: project.url ?? `${site}/projects`
  }))
};
---
<Layout
  title="Projects and Products | GG Nagarkar"
  description="Projects and products by GG Nagarkar across Applied AI Consulting, OpsRabbit, 7Targets, BMC Software, OpexSoftware, REAN Cloud, TCS, and patent-backed cloud automation."
  canonicalPath="/projects"
  jsonLd={jsonLd}
  breadcrumbs={[
    { name: 'Home', item: `${site}/` },
    { name: 'Projects', item: `${site}/projects` }
  ]}
>
  <h1 class="mb-4 text-3xl font-semibold text-slate-900">Projects</h1>
  <p class="mb-5 max-w-3xl text-slate-700">
    For deeper architecture notes, outcomes, scale, and lessons learned, see <a href="/built" class="underline">Things I've Built</a>.
  </p>
  <div class="grid gap-4 md:grid-cols-2">
    {projects.map((project) => <ProjectCard project={project} />)}
  </div>
</Layout>
