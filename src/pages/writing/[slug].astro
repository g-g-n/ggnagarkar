---
import Layout from '../../layouts/Layout.astro';
import { getWritingPosts, type WritingPost } from '../../lib/writing';

export function getStaticPaths() {
  return getWritingPosts().map((post) => ({
    params: { slug: post.slug },
    props: { post }
  }));
}

const { post } = Astro.props as { post: WritingPost };
const site = Astro.site?.toString().replace(/\/$/, '') ?? 'https://www.ggnagarkar.com';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.description,
  datePublished: post.date,
  dateModified: post.date,
  author: {
    '@type': 'Person',
    name: post.author,
    url: `${site}/about`
  },
  image: `${site}${post.image}`,
  mainEntityOfPage: `${site}${post.canonicalPath}`,
  keywords: post.tags
};
---
<Layout
  title={post.metaTitle}
  description={post.description}
  canonicalPath={post.canonicalPath}
  type="article"
  image={post.image}
  imageAlt={post.imageAlt}
  publishedTime={post.date}
  modifiedTime={post.date}
  tags={post.tags}
  jsonLd={jsonLd}
  breadcrumbs={[
    { name: 'Home', item: `${site}/` },
    { name: 'Writing & Activity', item: `${site}/writing` },
    { name: post.title, item: `${site}${post.canonicalPath}` }
  ]}
>
  <article class="card overflow-hidden">
    <img src={post.image} alt={post.imageAlt} class="aspect-[1200/630] w-full border-b border-slate-200 object-cover" />
    <div class="p-6 md:p-8">
      <a href="/writing" class="text-sm underline">Back to Writing & Activity</a>
      <p class="mt-6 text-sm font-semibold uppercase tracking-wide text-slate-500">
        {post.author} · {post.date}
      </p>
      <h1 class="mt-2 max-w-4xl text-3xl font-semibold leading-tight text-slate-950 md:text-4xl">{post.title}</h1>
      <p class="mt-4 max-w-3xl text-base leading-7 text-slate-700">{post.description}</p>
      <div class="mt-5 flex flex-wrap gap-2">
        {post.tags.map((tag) => (
          <span class="rounded-full bg-slate-100 px-2.5 py-1 text-xs font-medium text-slate-700">#{tag}</span>
        ))}
      </div>
      <div class="article-body mt-8 max-w-3xl" set:html={post.html} />
    </div>
  </article>
</Layout>
